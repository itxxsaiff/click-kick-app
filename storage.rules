rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn()
          ? firestore.get(
              /databases/(default)/documents/users/$(request.auth.uid)
            )
          : null;
    }

    function role() {
      return signedIn() ? userDoc().data.role : '';
    }

    function isStaff() {
      return role() in ['super_admin', 'superAdmin', 'admin', 'employee'];
    }

    match /admin_videos/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /contest_videos/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /contest_logos/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /participant_videos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && (request.auth.uid == userId || isStaff());
    }

    match /videos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && (request.auth.uid == userId || isStaff());
    }

    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /support_attachments/{userId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /sponsorship/{allPaths=**} {
      allow read, write: if isStaff();
    }

    match /sponsorship_applications/{applicationId}/{allPaths=**} {
      allow read, write: if isStaff() ||
        (
          signedIn() &&
          firestore.get(
            /databases/(default)/documents/sponsorship_applications/$(applicationId)
          ).data.sponsorId == request.auth.uid
        );
    }

    match /invoices/{userId}/{allPaths=**} {
      allow read, write: if isStaff() || (signedIn() && request.auth.uid == userId);
    }

    match /{allPaths=**} {
      allow read, write: if isStaff();
    }
  }
}
